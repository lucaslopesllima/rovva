# Configuração do servidor. Copie para .env e ajuste. NUNCA versione o .env real.

# OBRIGATÓRIO em produção. Assina os JWT E deriva a chave AES das senhas SMTP
# (crypto.ts). O boot ABORTA em produção se ausente ou no default inseguro.
# Gere um valor forte: openssl rand -base64 48
JWT_SECRET=

# TTL do token de sessão em segundos (default 7 dias).
JWT_TTL_SECONDS=604800

# Postgres. postgis/postgis para as buscas geo.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rs

PORT=8080
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# Nº de proxies reversos à frente da app. A app confia apenas nos últimos N saltos
# do X-Forwarded-For — impede spoof de XFF que burlaria o rate-limit por IP.
# 1 = um proxy (Docker/compose). 0 = ignora XFF (app exposta direto).
TRUST_PROXY_HOPS=1

# Rate limit dos endpoints de autenticação (por IP).
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=1 minute

# Memória da query de recomendação (SET LOCAL work_mem). Formato NNN kB/MB/GB.
RECOMMEND_WORK_MEM=64MB

# Evolution API (gateway WhatsApp não oficial). Vazio = integração desligada.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
WHATSAPP_WEBHOOK_URL=

# OBRIGATÓRIO em produção quando EVOLUTION_API_URL está setado: token que autentica
# o webhook (?token=). Sem ele o endpoint aceitaria eventos forjados de qualquer um.
# O boot aborta em produção com Evolution ligada e este token vazio.
WHATSAPP_WEBHOOK_TOKEN=

# Diretório (volume) da mídia descriptografada do WhatsApp. Vazio = base64 no Postgres.
WHATSAPP_MEDIA_DIR=

# Caminho do client buildado (Dockerfile seta). Vazio = sem estáticos (dev).
CLIENT_DIR=
