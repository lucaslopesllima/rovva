    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "9.1.3",
    "fastify": "5.8.5",
    "jose": "5.9.6",
    "pg": "8.13.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "typescript": "5.7.3"
  }
}
