# Copie para .env.e2e (git-ignorado). Usado pelo global-setup.ts e pelos
# fixtures que falam direto com o banco (fixtures/db.ts, seed/companies.sql).
# A stack sobe via docker-compose.e2e.yml, que expõe o Postgres em 55432.
E2E_DATABASE_URL=postgres://postgres:postgres@localhost:55432/rs_e2e
E2E_BASE_URL=http://localhost:5173
