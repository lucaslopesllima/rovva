# ─────────────────────────────────────────────────────────────────────────────
# .env — FONTE ÚNICA de configuração. Copie p/ .env e preencha.
# O docker-compose lê este arquivo e injeta cada variável no container que precisa
# dela (o grupo "container:" ao lado de cada seção indica quem consome).
# Wiring interno (URLs entre serviços, PORT, caminho de mídia) fica no compose —
# aqui só o que VOCÊ define: segredos, domínio e tuning.
# NÃO comite o .env (já está no .gitignore). Comentário inline após " # " é OK.
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco da aplicação · container: db ───────────────────────────────────────
POSTGRES_USER=postgres                     # usuário dono do banco da aplicação
POSTGRES_PASSWORD=troque-me                # senha do Postgres — gere: openssl rand -hex 16 (NÃO deixe "postgres")
POSTGRES_DB=rs                             # nome do banco da aplicação

# ── App / segurança · container: app ─────────────────────────────────────────
JWT_SECRET=troque-me                       # assina os JWT e deriva a chave AES das senhas SMTP — openssl rand -hex 32
TRUST_PROXY_HOPS=1                          # nº de proxies à frente do app (nginx = 1); trava spoof de X-Forwarded-For
JWT_TTL_SECONDS=604800                      # validade do token de login em segundos (604800 = 7 dias)
LOG_LEVEL=info                             # nível de log do app (debug|info|warn|error)
RECOMMEND_WORK_MEM=64MB                     # work_mem por sessão na query de recomendação (sort grande em memória)
AUTH_RATE_LIMIT_MAX=10                      # máx. de tentativas de login por IP dentro da janela abaixo
AUTH_RATE_LIMIT_WINDOW=1 minute            # janela do rate-limit de autenticação
PG_POOL_MAX=20                             # máx. de conexões simultâneas do app ao Postgres
PG_STATEMENT_TIMEOUT_MS=30000              # mata qualquer query da API que passar desse tempo (ms)

# ── Domínio / TLS · containers: nginx + certbot ──────────────────────────────
DOMAIN=rovva.seudominio.com.br         # domínio público; o A/AAAA record TEM que apontar pra VPS antes do deploy
ACME_EMAIL=voce@seudominio.com.br          # e-mail do Let's Encrypt (avisos de expiração do certificado)

# ── WhatsApp / Evolution · containers: app + evolution + redis ───────────────
EVOLUTION_API_KEY=troque-me                # chave da Evolution API; é a ÚNICA barreira do gateway — openssl rand -hex 32
WHATSAPP_WEBHOOK_TOKEN=troque-me           # valida os POSTs de webhook de entrada — openssl rand -hex 16
WA_WEB_VERSION=2.3000.1035194821           # versão do WhatsApp Web anunciada no handshake; atualize se o QR parar de gerar
EVOLUTION_REDIS_MAXMEMORY=512mb            # teto de RAM do Redis (cache do Evolution); calibre pela RAM da VPS

# ── Tuning do Postgres · container: db (calibre pela RAM da VPS) ──────────────
PG_SHARED_BUFFERS=2GB                       # buffers do Postgres — ~25% da RAM
PG_EFFECTIVE_CACHE_SIZE=6GB                 # estimativa de cache do SO p/ o planner — ~75% da RAM (não aloca)
PG_WORK_MEM=32MB                            # memória por operação de sort/hash de cada query
PG_MAINTENANCE_WORK_MEM=1GB                 # memória p/ VACUUM/CREATE INDEX
PG_SHM_SIZE=1g                             # tamanho do /dev/shm do container (hash/sort paralelo)

# ── VPS / deploy · host (não vai pra container) ──────────────────────────────
SSH_PORT=2222                              # porta do SSH após o hardening (./deploy.sh --lock-ssh)
APP_PORT=8080                              # só p/ debug local em loopback; em prod o app NÃO publica porta (nginx expõe 80/443)
