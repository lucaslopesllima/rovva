# Copy to .env and adjust. docker-compose reads this automatically.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=rs

# REQUIRED: secret for signing JWTs (use a long random string)
JWT_SECRET=change-this-to-a-long-random-secret

# host port the app is published on
APP_PORT=8080

# raised per-session for the recommendation sort
RECOMMEND_WORK_MEM=64MB

# Postgres tuning (docker-compose.prod.yml). Calibrate to the VPS:
# PG_SHARED_BUFFERS ~25% of RAM, PG_EFFECTIVE_CACHE_SIZE ~75% of RAM.
PG_SHARED_BUFFERS=2GB
PG_EFFECTIVE_CACHE_SIZE=6GB
PG_WORK_MEM=32MB
PG_MAINTENANCE_WORK_MEM=1GB
PG_SHM_SIZE=1g

# kill any API query running longer than this (ms)
PG_STATEMENT_TIMEOUT_MS=30000

# Rate limit dos endpoints de autenticação (por IP)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=1 minute

# WhatsApp / Evolution API. Em produção o docker-compose.prod.yml sobe os serviços
# evolution + evolution_db + redis, e o app já aponta pra eles internamente — você
# NÃO precisa setar EVOLUTION_API_URL/WHATSAPP_WEBHOOK_URL na mão, só os segredos
# abaixo (ambos OBRIGATÓRIOS em prod: o compose recusa subir se vierem vazios).
#   - EVOLUTION_API_KEY  = AUTHENTICATION_API_KEY da Evolution; é a ÚNICA barreira
#                          do gateway (o painel não é publicado). Use algo longo e
#                          aleatório em prod, ex.: openssl rand -hex 32. NÃO deixe
#                          o valor de dev.
#   - WHATSAPP_WEBHOOK_TOKEN = valida os POSTs de webhook de entrada (vai na query).
EVOLUTION_API_KEY=dev-evolution-key
WHATSAPP_WEBHOOK_TOKEN=dev-webhook-token
# Versão do WhatsApp Web anunciada no handshake (Evolution). Atualize pelo
# baileys-version.json do WhiskeySockets/Baileys se o QR parar de gerar.
# WA_WEB_VERSION=2.3000.1035194821
# Teto de memória do Redis (cache do Evolution). Calibre pela RAM da VPS.
# EVOLUTION_REDIS_MAXMEMORY=512mb
# Mídia do WhatsApp em disco (volume) em vez de base64 no Postgres. Vazio = base64.
# Nos compose já vem setado pra /data/wa-media.
# WHATSAPP_MEDIA_DIR=/data/wa-media
