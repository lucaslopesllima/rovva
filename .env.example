# Copy to .env and adjust. docker-compose reads this automatically.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=rs

# REQUIRED: secret for signing JWTs (use a long random string)
JWT_SECRET=change-this-to-a-long-random-secret

# host port the app is published on
APP_PORT=8080

# raised per-session for the recommendation sort
RECOMMEND_WORK_MEM=64MB

# Postgres tuning (docker-compose.prod.yml). Calibrate to the VPS:
# PG_SHARED_BUFFERS ~25% of RAM, PG_EFFECTIVE_CACHE_SIZE ~75% of RAM.
PG_SHARED_BUFFERS=2GB
PG_EFFECTIVE_CACHE_SIZE=6GB
PG_WORK_MEM=32MB
PG_MAINTENANCE_WORK_MEM=1GB
PG_SHM_SIZE=1g

# kill any API query running longer than this (ms)
PG_STATEMENT_TIMEOUT_MS=30000
